-- 03_recursion.lang
-- Рекурсивная функция: факториал.
-- expect_stdout:
-- 3628800
-- expect_exit: 0

fn factorial(n: int32) -> int32 @pure {
    return if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    };
}

fn main() -> int32 {
    println(factorial(10));   -- 10! == 3628800
    return 0;
}
