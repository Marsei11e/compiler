-- 03_float_arith.lang
-- Вещественные литералы и арифметика float64.
-- Проверяет: float-деление НЕ ошибка (см. consistency A.1).
-- expect_stdout:
-- 6.280000
-- 1.500000
-- 0.500000
-- expect_exit: 0

fn main() -> int32 {
    println(3.14 + 3.14);   -- 6.28
    println(3.0 / 2.0);     -- 1.5
    println(2.0 - 1.5);     -- 0.5 (если арифметика IEEE 754 точна для этого случая — точна)
    return 0;
}